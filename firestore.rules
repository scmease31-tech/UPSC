rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Articles: public read (app needs this without login), no public write
    match /articles/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Quiz questions: public read
    match /quizQuestions/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // All other collections: authenticated read/write
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
