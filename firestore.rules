rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data: private to the signed-in owner ────────────────────────────
    // Profiles, bookmarks, progress etc. are stored under users/{uid}.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{sub=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Public study content ─────────────────────────────────────────────────
    // Readable by everyone so the app works without login (offline-first study
    // app). Writes happen only through the Admin SDK / scraper, which bypasses
    // these rules, so public writes stay disabled.
    match /articles/{doc}         { allow read: if true; allow write: if false; }
    match /quizQuestions/{doc}    { allow read: if true; allow write: if false; }
    match /vocabulary/{doc}       { allow read: if true; allow write: if false; }
    match /govtSchemes/{doc}      { allow read: if true; allow write: if false; }
    match /flashcards/{doc}       { allow read: if true; allow write: if false; }
    match /currentAffairs/{doc}   { allow read: if true; allow write: if false; }
    match /mockTests/{doc}        { allow read: if true; allow write: if false; }
    match /revisionNotes/{doc}    { allow read: if true; allow write: if false; }
    match /dailyFacts/{doc}       { allow read: if true; allow write: if false; }
    match /pyqBank/{doc}          { allow read: if true; allow write: if false; }
    match /studyNotes/{doc}       { allow read: if true; allow write: if false; }
    match /weeklyMagazines/{doc}  { allow read: if true; allow write: if false; }
    match /syllabus/{doc}         { allow read: if true; allow write: if false; }
    match /answerWriting/{doc}    { allow read: if true; allow write: if false; }
    match /subjects/{doc}         { allow read: if true; allow write: if false; }
    match /books/{doc}            { allow read: if true; allow write: if false; }
    match /book_chapters/{doc}    { allow read: if true; allow write: if false; }

    // ── Everything else: require authentication (safe default) ────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
